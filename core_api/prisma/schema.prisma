// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum MemberRole {
  OWNER
  ADMIN
  COLLAB
  GUEST
}

enum TokenType {
  REFRESH
  EMAIL
  PASSWORD
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatuts {
  BACKLOG
  TODO
  ON_GOING
  ON_TEST
  FINISHED
}

model User {
  id String @id @default(uuid()) @db.VarChar(36)
  firstname String @db.VarChar(100)
  lastname String @db.VarChar(100)
  email String @unique @db.VarChar(320)
  username String @unique @db.VarChar(100)
  password String @db.VarChar(200)
  is_confirmed Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  projects Project_member[]
  tokens Token[]
  tasks_assigned User_task[]

  @@index([firstname])
  @@index([lastname])
}

model Project {
  id String @id @default(uuid()) @db.VarChar(36)
  title String @db.VarChar(200)
  description String? @db.Text
  date_start DateTime @default(now())
  date_end DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  members Project_member[]
  task_categories Task_category[]
  tasks Task[]

  @@index([title])
  @@index([date_start, date_end])
}

model Project_member {
  role MemberRole
  is_confirmed Boolean @default(false)

  user User @relation(fields: [user_id], references: [id])
  user_id String @db.VarChar(36)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String @db.VarChar(36)

  @@id([user_id, project_id], name:"user_project_id")
  @@index([project_id])
}

model Token {
  token String @unique @db.VarChar(500)
  type TokenType
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @db.VarChar(36)

  @@id([user_id, type], name:"token_type_id")
}

model Task_category {
  id String @id @default(uuid()) @db.VarChar(36)
  title String @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String @db.VarChar(36)

  tasks Task[]

@@unique([title, project_id], name: "task_category_title_project")
  @@index([project_id])
}

model Task {
  id String @id @default(uuid()) @db.VarChar(36)
  title String @db.VarChar(200)
  description String? @db.Text
  priority TaskPriority
  statuts TaskStatuts
  image String @db.VarChar(250)
  date_start DateTime? 
  delay Int @db.UnsignedInt
  worked_time Int @default(0) @db.UnsignedInt
  date_end DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  task_category Task_category @relation(fields: [task_category_id], references: [id], onDelete: Cascade)
  task_category_id String @db.VarChar(36)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String @db.VarChar(36)

  subtasks Subtask[]
  user_assigned User_task[]

  @@index([project_id])
  @@index([task_category_id])
  @@index([statuts])
  @@index([priority])
}

model Subtask {
  id String @id @default(uuid()) @db.VarChar(36)
  description String @db.Text
  is_done Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  task_id String @db.VarChar(36)

  @@index([task_id])
}

model User_task {
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @db.VarChar(36)
  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  task_id String @db.VarChar(36)

  @@id([user_id, task_id], name:"user_task_id")

  @@index([task_id])
}
