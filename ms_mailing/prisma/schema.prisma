generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum MailStatus {
  PENDING
  SENT
  FAILED
}

model MailTemplate {
  id         String   @id @default(uuid())
  name       String   @unique
  subject    String
  bodyHtml   String
  bodyText   String?
  variables  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  logs       MailLog[]
}

model MailLog {
  id          String   @id @default(uuid())
  to          String
  status      MailStatus @default(PENDING)
  response    Json?
  createdAt   DateTime   @default(now())

  templateId  String
  template    MailTemplate @relation(fields: [templateId], references: [id])
}